# Required for real sessions. Get one at https://platform.claude.com
ANTHROPIC_API_KEY=sk-ant-...

# Run without an API key: streams canned debate so you can demo the UI for free.
MOCK_LLM=0

# Hard per-session spend ceiling in USD. The session stops calling the LLM
# once this is reached and compiles the plan from whatever was decided.
SESSION_BUDGET_USD=2.00

# Turn caps (cost + runaway protection)
MAX_TURNS_PER_ROUND=4
GLOBAL_TURN_CAP=40

# --- Auth + per-user guardrails (backend) ---
# Sign-in is required to start a session, and each non-owner user has a LIFETIME
# spend cap of FREE_USER_BUDGET_USD (tracked in Supabase). The owner is unlimited.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=   # Project Settings -> API -> service_role (SECRET)
OWNER_EMAIL=you@example.com
FREE_USER_BUDGET_USD=2.00
# Set to 0 ONLY for local/mock dev to bypass sign-in. Keep 1 in production.
REQUIRE_AUTH=1
