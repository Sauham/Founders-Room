# Required for real sessions. Get one at https://platform.claude.com
ANTHROPIC_API_KEY=sk-ant-...

# Run without an API key: streams canned debate so you can demo the UI for free.
MOCK_LLM=0

# Hard per-session spend ceiling in USD. The session stops calling the LLM
# once this is reached and compiles the plan from whatever was decided.
SESSION_BUDGET_USD=2.00

# Turn caps (cost + runaway protection)
MAX_TURNS_PER_ROUND=4
GLOBAL_TURN_CAP=40
